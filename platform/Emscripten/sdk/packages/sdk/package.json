{
  "name": "@opensweeteditor/sdk",
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "pnpm --filter @opensweeteditor/core run build && pnpm --filter @opensweeteditor/widget run build && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@opensweeteditor/core": "workspace:*",
    "@opensweeteditor/widget": "workspace:*"
  }
}
